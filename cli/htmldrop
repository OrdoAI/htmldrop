#!/usr/bin/env bash
set -euo pipefail

ENDPOINT="${HTMLDROP_URL:-https://baseurl.ai}"
NO_INLINE=false

usage() {
  cat <<'EOF'
Usage: htmldrop <file>

Upload an HTML or Markdown file and get a shareable link.
Relative images, CSS, and JS are automatically inlined as base64.

  htmldrop ./report.html
  htmldrop ~/Documents/notes.md
  htmldrop file:///Users/me/page.html

Options:
  --no-inline          Skip asset inlining, upload HTML as-is
  -e, --endpoint URL   Override upload endpoint (default: https://baseurl.ai)
  -h, --help           Show this help

Environment:
  HTMLDROP_URL         Override upload endpoint
EOF
  exit 0
}

die() { echo "error: $1" >&2; exit 1; }

FILE=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage ;;
    --no-inline) NO_INLINE=true; shift ;;
    -e|--endpoint) ENDPOINT="$2"; shift 2 ;;
    *)
      [[ -z "$FILE" ]] && FILE="$1" || die "unexpected argument: $1"
      shift ;;
  esac
done

[[ -n "$FILE" ]] || die "no file specified. Run 'htmldrop --help' for usage."

FILE="${FILE#file://}"
FILE="${FILE/#\~/$HOME}"

[[ -f "$FILE" ]] || die "file not found: $FILE"

FILEDIR="$(cd "$(dirname "$FILE")" && pwd)"
EXT="${FILE##*.}"
EXT="$(printf '%s' "$EXT" | tr '[:upper:]' '[:lower:]')"
FILENAME="$(basename "$FILE")"
CONTENT="$(cat "$FILE")"

# Convert Markdown to HTML
if [[ "$EXT" == "md" || "$EXT" == "markdown" ]]; then
  MD_CSS='body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;max-width:48rem;margin:0 auto;padding:2rem;line-height:1.6;color:#24292e}h1,h2,h3,h4,h5,h6{margin-top:1.5em;margin-bottom:.5em;font-weight:600}h1{font-size:2em;border-bottom:1px solid #eee;padding-bottom:.3em}h2{font-size:1.5em;border-bottom:1px solid #eee;padding-bottom:.3em}code{background:#f6f8fa;padding:.2em .4em;border-radius:3px;font-size:85%}pre{background:#f6f8fa;padding:1em;border-radius:6px;overflow-x:auto}pre code{background:none;padding:0}blockquote{border-left:4px solid #dfe2e5;padding:0 1em;color:#6a737d;margin:1em 0}table{border-collapse:collapse;width:100%}th,td{border:1px solid #dfe2e5;padding:.5em .75em}th{background:#f6f8fa}img{max-width:100%}a{color:#0366d6}ul,ol{padding-left:2em}hr{border:none;border-top:1px solid #eee;margin:1.5em 0}'

  if command -v marked &>/dev/null; then
    RENDERED="$(marked --gfm <<< "$CONTENT")"
  elif command -v npx &>/dev/null; then
    RENDERED="$(npx -y marked --gfm <<< "$CONTENT" 2>/dev/null)" || die "markdown conversion failed"
  elif command -v python3 &>/dev/null; then
    RENDERED="$(python3 -c "
import sys, html as h
text = sys.stdin.read()
print('<pre>' + h.escape(text) + '</pre>')
" <<< "$CONTENT")"
    echo "warning: no markdown renderer found, uploaded as preformatted text" >&2
  else
    die "no markdown renderer found. Install marked: npm i -g marked"
  fi

  CONTENT="<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>${MD_CSS}</style></head><body>${RENDERED}</body></html>"
fi

# Inline relative assets
if [[ "$NO_INLINE" == false ]]; then
  export FILEDIR
  CONTENT="$(python3 -c "
import sys, os, re, base64, mimetypes, shutil, subprocess, tempfile

html = sys.stdin.read()
basedir = os.environ['FILEDIR']
inlined = 0
missing = []
cwebp = shutil.which('cwebp')

mimetypes.init()

def is_relative(src):
    if not src: return False
    for prefix in ('data:', 'http://', 'https://', '//', '#', 'javascript:'):
        if src.startswith(prefix): return False
    return True

def maybe_compress(path, mime, raw):
    if mime not in ('image/png', 'image/jpeg') or not cwebp or len(raw) < 4096:
        return raw, mime
    out_path = None
    try:
        fd, out_path = tempfile.mkstemp(suffix='.webp')
        os.close(fd)
        result = subprocess.run([cwebp, '-quiet', '-q', '82', path, '-o', out_path], stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        if result.returncode != 0 or not os.path.isfile(out_path):
            return raw, mime
        with open(out_path, 'rb') as f:
            webp = f.read()
        if webp and len(webp) < len(raw):
            return webp, 'image/webp'
    except Exception:
        return raw, mime
    finally:
        if out_path:
            try:
                os.unlink(out_path)
            except OSError:
                pass
    return raw, mime

def resolve_and_inline(src):
    global inlined, missing
    path = os.path.normpath(os.path.join(basedir, src))
    if not os.path.isfile(path):
        missing.append(src)
        return None
    mime, _ = mimetypes.guess_type(path)
    if not mime:
        ext = os.path.splitext(path)[1].lower()
        mime = {'.svg': 'image/svg+xml', '.webp': 'image/webp', '.avif': 'image/avif', '.ico': 'image/x-icon'}.get(ext, 'application/octet-stream')
    with open(path, 'rb') as f:
        raw = f.read()
    raw, mime = maybe_compress(path, mime, raw)
    data = base64.b64encode(raw).decode()
    inlined += 1
    return f'data:{mime};base64,{data}'

def replace_img(m):
    prefix, quote, src = m.group(1), m.group(2), m.group(3)
    if not is_relative(src): return m.group(0)
    uri = resolve_and_inline(src)
    return f'{prefix}{quote}{uri}{quote}' if uri else m.group(0)

def replace_css(m):
    global inlined
    prefix, quote, href = m.group(1), m.group(2), m.group(3)
    if not is_relative(href): return m.group(0)
    path = os.path.normpath(os.path.join(basedir, href))
    if not os.path.isfile(path):
        missing.append(href)
        return m.group(0)
    with open(path, 'r') as f:
        css = f.read()
    inlined += 1
    return f'<style>{css}</style>'

def replace_js(m):
    global inlined
    prefix, quote, src, suffix = m.group(1), m.group(2), m.group(3), m.group(4)
    if not is_relative(src): return m.group(0)
    path = os.path.normpath(os.path.join(basedir, src))
    if not os.path.isfile(path):
        missing.append(src)
        return m.group(0)
    with open(path, 'r') as f:
        js = f.read()
    inlined += 1
    return f'<script>{js}</script>'

html = re.sub(r'(<img\b[^>]*\bsrc\s*=\s*)([\"\\x27])([^\"\\x27]+)\2', replace_img, html, flags=re.I)
html = re.sub(r'(<link\b[^>]*\bhref\s*=\s*)([\"\\x27])([^\"\\x27]+)\2', replace_css, html, flags=re.I)
html = re.sub(r'(<script\b[^>]*\bsrc\s*=\s*)([\"\\x27])([^\"\\x27]+)\2([^>]*>\s*</script>)', replace_js, html, flags=re.I)

if inlined > 0 or missing:
    parts = []
    if inlined: parts.append(f'{inlined} asset(s) inlined')
    if missing: parts.append(f'{len(missing)} not found: {\", \".join(missing[:5])}')
    print(', '.join(parts), file=sys.stderr)

sys.stdout.write(html)
" <<< "$CONTENT")" || die "asset inlining failed"
fi

# Upload
HTML_TMP="$(mktemp)"
PAYLOAD_TMP="$(mktemp)"
trap 'rm -f "$HTML_TMP" "$PAYLOAD_TMP"' EXIT
printf '%s' "$CONTENT" > "$HTML_TMP"
jq -n --rawfile html "$HTML_TMP" --arg filename "$FILENAME" '{html: $html, filename: $filename}' > "$PAYLOAD_TMP"

RESPONSE="$(curl -sf -X POST "${ENDPOINT}/api/upload" \
  -H "Content-Type: application/json" \
  --data-binary "@${PAYLOAD_TMP}")" || die "upload failed"

URL="$(echo "$RESPONSE" | jq -r '.url')"
ID="$(echo "$RESPONSE" | jq -r '.id')"
EXPIRES="$(echo "$RESPONSE" | jq -r '.expiresAt')"

echo "$URL"

if [[ -t 1 ]]; then
  echo "  id: $ID · expires: ${EXPIRES%T*}" >&2
  if command -v pbcopy &>/dev/null; then
    echo -n "$URL" | pbcopy
    echo "  (copied to clipboard)" >&2
  fi
fi
